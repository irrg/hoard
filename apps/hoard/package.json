{
  "name": "@irrg/hoard",
  "version": "0.2.0",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/irrg/hoard",
  "type": "module",
  "bin": {
    "hoard": "./dist/bin/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src bin tests",
    "fmt": "oxfmt src bin tests",
    "fmt:check": "oxfmt --check src bin tests",
    "hoard": "node --import tsx/esm --conditions=development bin/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "cli-progress": "^3.12.0",
    "@irrg/bundleofholding-hoard": "workspace:*",
    "@irrg/drivethru-hoard": "workspace:*",
    "@irrg/humblebundle-hoard": "workspace:*",
    "@irrg/itchio-hoard": "workspace:*"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "tsx": "^4.19.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
